# SquarefeetX - Master .gitignore

# ====================================================================
# OS & System Files
# ====================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ====================================================================
# IDEs & Editors
# ====================================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~
*.sublime-project
*.sublime-workspace

# ====================================================================
# Node.js & React Frontend (squarefeet-x-frontend)
# ====================================================================
node_modules/
jspm_packages/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
lerna-debug.log*

# Frontend Build directories
/squarefeet-x-frontend/dist/
/squarefeet-x-frontend/build/
/squarefeet-x-frontend/out/

# Env & sensitive files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*

# ====================================================================
# Java & Spring Boot Backend (squarefeet-x-backend)
# ====================================================================
# Compiled class files
*.class

# Log files
*.log
squarefeet-x-backend/**/*.log
property-service.log
property-service-err.log

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven build directories
target/
squarefeet-x-backend/**/target/
.mvn/wrapper/maven-wrapper.jar
.mvn/

# Gradle build files (if any exist)
.gradle/
build/
squarefeet-x-backend/**/build/

# Spring Boot & Database temporary/local configuration overrides
application-local.properties
application-dev.properties
squarefeet-x-backend/**/application-local.properties
squarefeet-x-backend/**/application-dev.properties

# ====================================================================
# Databases & Local Data Directories
# ====================================================================
mongodb_data/
/mongodb_data/
*.db
*.sqlite

# ====================================================================
# Temporary files and crash dumps
# ====================================================================
.temp/
.tmp/
temp/
tmp/
.sass-cache/
.eslintcache
.parcel-cache
.cache/
